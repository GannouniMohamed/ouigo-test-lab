{
	"$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true
		}
	},
	"files": {
		"ignore": [
			"out/**",
			"node_modules/**",
			"docs/**",
			"test-results/**",
			"playwright-report/**",
			"release/**"
		]
	},
	"formatter": {
		"lineEnding": "lf"
	}
}
